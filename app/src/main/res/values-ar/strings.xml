    <string name="monday_fasting_title">صيام يوم الإثنين</string>
    <string name="thursday_fasting_title">صيام يوم الخميس</string>
    <string name="monday_thursday_fasting_subtitle">قال رسول الله ﷺ : تُعرَضُ الأعمالُ يومَ الاثنينِ والخميسِ فأحبُّ أن يُعرَضَ عملي وأنا صائمٌ.</string>
    <string name="white_days_fasting_title">صيام الأيام البِيض</string>
    <string name="white_days_fasting_subtitle">عن مِلْحَانَ الْقَيْسِيُّ: كانَ رسولُ اللَّهِ -صلَّى اللَّهُ علَيهِ وسلَّمَ- يأمرُنا أن نصومَ البيضَ ثَلاثَ عشرةَ وأربعَ عشرةَ وخَمسَ عَشرةَ قالَ وقالَ هُنَّ كَهَيئةِ الدَّهرِ</string>
    <string name="arfa_fasting_title">صيام يوم عرفة</string>
    <string name="arfa_fasting_subtitle">قال رسول الله ﷺ : صيام يوم عرفة أحتسب على الله أن يكفر السنة التي قبله والسنة التي بعده.</string>
    <string name="tasua_fasting_title">صيام يوم تاسوعاء</string>
    <string name="tasua_fasting_subtitle">قال رسول الله ﷺ : فَإِذَا كانَ العَامُ المُقْبِلُ -إنْ شَاءَ اللَّهُ- صُمْنَا اليومَ التَّاسِعَ.</string>
    <string name="ashora_fasting_title">صيام يوم عاشوراء</string>
    <string name="ashora_fasting_subtitle">سُئِلَ  رسول الله ﷺ عن صوم عاشوراء فقال: يُكَفِّرُ السَّنَةَ المَاضِيَةَ.</string>
    <string name="shawwal_fasting_title">صيام الست من شوال</string>
    <string name="shawwal_fasting_subtitle">قال رسول الله ﷺ : من صام رمضانَ وأتبعَهُ بستٍّ من شوالَ فكأنما صام الدهرَ.</string>
    <string name="ramadan_event_title">شهر رمضان</string>
    <string name="ramadan_event_subtitle">قال رسول الله ﷺ : إِذا جَاءَ رَمَضَانُ، فُتِّحَتْ أَبْوَابُ الجنَّةِ، وغُلِّقَت أَبْوَابُ النَّارِ، وصُفِّدتِ الشياطِينُ.</string>
    <string name="ramadan_last_10_days_event_title">العشر الأواخر من شهر رمضان</string>
    <string name="ramadan_last_10_days_event_subtitle">قال الله تعالى : لَيْلَةُ الْقَدْرِ خَيْرٌ مِّنْ أَلْفِ شَهْرٍ [القدر:٣]</string>
    <string name="dhu_al_hijjah_first_10_days_event_title">العشر الأوائل من شهر ذي الحجة</string>
    <string name="dhu_al_hijjah_first_10_days_event_subtitle">قال رسول الله ﷺ : ما من أيامٍ أعْظَمُ عندَ اللهِ ولَا أَحَبُّ إلى اللهِ العملُ فيهِنَّ مِنْ أَيَّامِ العشْرِ.</string>
    <string name="eid_al_fitr_event_title">عيد فطر مبارك</string>
    <string name="eid_al_adha_event_title">عيد أضحى مبارك</string>
    <string name="eids_event_subtitle">قال الله تعالى : ذَٰلِكَ وَمَن يُعَظِّمْ شَعَائِرَ اللَّهِ فَإِنَّهَا مِن تَقْوَى الْقُلُوبِ [الحج:٣٢]</string>
    <string name="friday_event_title">جمعة مباركة</string>
    <string name="friday_event_subtitle">قال رسول الله ﷺ : من قرأ سورةَ الكهفِ في يومِ الجمعةِ ، أضاء له من النورِ ما بين الجمُعتَينِ.</string>
    <string name="muharram_event_title">شهر محرم</string>
    <string name="rajab_event_title">شهر رجب</string>
    <string name="dhu_al_qadah_event_title">شهر ذي القعدة</string>
    <string name="dhu_al_hijjah_event_title">شهر ذي الحجة</string>
    <string name="sacred_months_event_subtitle">قال الله تعالى عن الأشهر الحُرُم: فَلا تَظْلِمُوا فِيهِنَّ أَنْفُسَكُمْ [التوبة:٣٦]</string>

