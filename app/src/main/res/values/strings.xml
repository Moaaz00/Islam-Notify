    <string name="sounds_fajr_notification_title">Fajr</string>
    <string name="sounds_iqama_fajr_notification_title">the iqama of Fajr</string>
    <string name="sounds_fajr_notification_subtitle">The Messenger of Allah (ﷺ) said: One who performs Isha prayer in congregation, is as if he has performed Salat for half of the night. And one who performs the Fajr prayer in congregation, is as if he has performed Salat the whole night.</string>

    <string name="sounds_sunrise_notification_title">Sunrise</string>
    <string name="sounds_sunrise_notification_subtitle">None has the right to be worshipped but Allah, Alone without partner, to Him belongs all that exists, and to Him is the praise, He gives life and causes death, and He is powerful over all things</string>

    <string name="sounds_duha_notification_title">Duha</string>
    <string name="sounds_duha_notification_subtitle">The Messenger of Allah (ﷺ) said: The prayer of those who are penitent is observed when your weaned camels feel the heat of the sun.</string>

    <string name="sounds_zuhr_notification_title">Dhuhr</string>
    <string name="sounds_iqama_zuhr_notification_title">the iqama of Dhuhr</string>
    <string name="sounds_zuhr_notification_subtitle">The Messenger of Allah (ﷺ) said: The prayer in congregation is twenty seven times superior to the prayer offered by person alone.</string>

    <string name="sounds_jummah_notification_title">Jumu\'ah</string>
    <string name="sounds_jummah_notification_subtitle">The Messenger of Allah (ﷺ) said: The five Salat, and from one Jumu\'ah prayer to the (next) Jumu\'ah prayer, and from Ramadan to Ramadan are expiations for the (sins) committed in between; provided the major sins are not committed</string>

    <string name="sounds_asr_notification_title">Asr</string>
    <string name="sounds_iqama_asr_notification_title">the iqama of Asr</string>
    <string name="sounds_asr_notification_subtitle">The Messenger of Allah (ﷺ) said: He who purified himself in his house, and then he walked to one of the houses of Allah for the sake of performing a Fard out of the Fara\'id of Allah, both his steps as one of them would obliterate his sin and the second one would raise his status.</string>

    <string name="sounds_sunset_notification_title">Maghrib</string>
    <string name="sounds_iqama_sunset_notification_title">the iqama of Maghrib</string>
    <string name="sounds_sunset_notification_subtitle">The Messenger of Allah (ﷺ) said: Allah will prepare for him who goes to the mosque morning and in the afternoon an honorable place in Paradise with good hospitality for every morning and afternoon goings.</string>

    <string name="sounds_isha_notification_title">Isha</string>
    <string name="sounds_iqama_isha_notification_title">the iqama of Isha</string>
    <string name="sounds_isha_notification_subtitle">The Messenger of Allah (ﷺ) said: One who performs Isha prayer in congregation, is as if he has performed Salat for half of the night. And one who performs the Fajr prayer in congregation, is as if he has performed Salat the whole night.</string>

    <string name="sounds_midnight_notification_title">Midnight</string>
    <string name="sounds_midnight_notification_subtitle">None has the right to be worshipped but Allah, Alone without partner, to Him belongs all that exists, and to Him is the praise, He gives life and causes death, and He is powerful over all things</string>

    <string name="sounds_last_third_notification_title">the Last third</string>
    <string name="sounds_last_third_notification_subtitle">Allah says regarding those who pray Qiyam al-Layl: No soul can imagine what delights are kept in store for them as a reward for what they used to do. [32:17]</string>

